---
// [id].astro - 器具詳細ページ
// 動的ルーティングで各器具の詳細情報を表示

import Base from '../../layouts/Base.astro';
import GearCard from '../../components/GearCard.astro';

// データの読み込み
import gearData from '../../data/gear.json';
import brandsData from '../../data/brands.json';

// 静的パス生成（全器具のIDからパスを生成）
export function getStaticPaths() {
  return gearData.map((gear) => ({
    params: { id: gear.id },
  }));
}

// URLパラメータから器具IDを取得
const { id } = Astro.params;

// 該当する器具データを検索
const gear = gearData.find(g => g.id === id);
if (!gear) return Astro.redirect('/404');

// ブランドデータを検索
const brand = brandsData.find(b => b.id === gear.brand);

// 関連器具データを取得（同じカテゴリの最初の3つ）
const relatedGear = gearData
  .filter(g => g.category === gear.category && g.id !== gear.id)
  .slice(0, 3);

// カテゴリの表示名を整形
const categoryLabel = gear.category.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');

// 抽出方法の表示名を整形
const methodLabel = gear.brewMethod.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');

// JSON-LD構造化データ（Article schema）
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": gear.name,
  "description": gear.description,
  "image": new URL(gear.image, Astro.site).href,
  "author": {
    "@type": "Organization",
    "name": "Coffee Gear Archive",
  },
  "publisher": {
    "@type": "Organization",
    "name": "Coffee Gear Archive",
  },
  "datePublished": new Date().toISOString().split('T')[0],
};
---

<Base
  title={gear.name}
  description={gear.description.slice(0, 160)}
  jsonLd={articleJsonLd}
>
  <!-- 一覧への戻りリンク -->
  <div class="container" style="padding-top: calc(var(--space-md) + 60px);">
    <a href="/" style="font-size: 0.85rem; color: var(--color-text-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 0.3rem; transition: color 0.2s;">
      <span>&larr;</span> Back to Gear
    </a>
  </div>

  <!-- 器具詳細ヘッダー -->
  <div class="page-header" style="padding-top: var(--space-sm);">
    <p style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent); margin-bottom: 0.5rem; font-weight: 600;">
      {categoryLabel} · {methodLabel}
    </p>
    <h1 class="page-header__title">{gear.name}</h1>
    <p class="page-header__description">{brand?.name || gear.brand} — {gear.material}</p>
  </div>

  <div class="container container--narrow">
    <!-- 器具画像 -->
    <div style="padding: var(--space-lg) 0;">
      <img src={gear.image} alt={gear.name} style="width: 100%; border-radius: var(--radius-md);" />
    </div>

    <!-- 価格表示 -->
    <div style="display: flex; gap: var(--space-md); align-items: center; margin-bottom: var(--space-lg);">
      <span style="font-size: 1.8rem; font-weight: 700; color: var(--color-danger);">${gear.price}</span>
    </div>

    <!-- 説明文 -->
    <p style="margin-bottom: var(--space-lg); line-height: 1.9;">{gear.description}</p>

    <!-- スペック表 -->
    <div class="spec-grid">
      <div class="spec-item">
        <span class="spec-item__label">Category</span>
        <span class="spec-item__value">{categoryLabel}</span>
      </div>
      <div class="spec-item">
        <span class="spec-item__label">Material</span>
        <span class="spec-item__value">{gear.material}</span>
      </div>
      <div class="spec-item">
        <span class="spec-item__label">Brew Method</span>
        <span class="spec-item__value">{methodLabel}</span>
      </div>
      <div class="spec-item">
        <span class="spec-item__label">Capacity</span>
        <span class="spec-item__value">{gear.capacity}</span>
      </div>
      <div class="spec-item">
        <span class="spec-item__label">Brand</span>
        <span class="spec-item__value">
          <a href={`/brands/${gear.brand}/`} style="color: var(--color-accent);">{brand?.name || gear.brand}</a>
        </span>
      </div>
      <div class="spec-item">
        <span class="spec-item__label">Price</span>
        <span class="spec-item__value">${gear.price}</span>
      </div>
    </div>

    <!-- 特徴リスト -->
    <div style="padding: var(--space-lg) 0;">
      <h2 style="margin-bottom: var(--space-md);">Key Features</h2>
      <ul style="list-style: none; padding: 0;">
        {gear.features.map((feature: string) => (
          <li style="padding: 0.6rem 0; border-bottom: 1px solid var(--color-border); color: var(--color-text-sub); display: flex; align-items: center; gap: 0.5rem;">
            <span style="color: var(--color-accent);">&#9670;</span>
            {feature}
          </li>
        ))}
      </ul>
    </div>

    <!-- 購入リンク（URLがある場合のみ表示） -->
    {(gear.amazonUrl || gear.amazonUKUrl || gear.rakutenUrl) && (
      <div style="padding: var(--space-md) 0 var(--space-lg);">
        <h2 style="margin-bottom: var(--space-md);">Where to Buy</h2>
        <div class="buy-links">
          {gear.amazonUrl && (
            <a href={gear.amazonUrl} class="btn btn--filled" target="_blank" rel="noopener noreferrer">Amazon</a>
          )}
          {gear.amazonUKUrl && (
            <a href={gear.amazonUKUrl} class="btn btn--filled" target="_blank" rel="noopener noreferrer">Amazon UK</a>
          )}
          {gear.rakutenUrl && (
            <a href={gear.rakutenUrl} class="btn" target="_blank" rel="noopener noreferrer">🛒 楽天市場</a>
          )}
        </div>
      </div>
    )}

    <!-- 関連器具 -->
    {relatedGear.length > 0 && (
      <div style="padding: var(--space-lg) 0; border-top: 1px solid var(--color-border);">
        <h2 style="margin-bottom: var(--space-md);">Related Gear</h2>
        <div class="related-grid">
          {relatedGear.map((rg: any) => (
            <GearCard
              id={rg.id}
              name={rg.name}
              brand={rg.brand}
              category={rg.category}
              brewMethod={rg.brewMethod}
              price={rg.price}
              image={rg.image}
            />
          ))}
        </div>
      </div>
    )}
  </div>
</Base>
