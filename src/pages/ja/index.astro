---
// ja/index.astro - 日本語版トップページ
// 英語版と同じ構造で、テキストのみ日本語に

import Base from '../../layouts/Base.astro';
import gearData from '../../data/gear.json';
---

<Base
  title="Coffee Gear Archive"
  description="コーヒー器具の完全データベース。ドリッパー、グラインダー、ケトル、エスプレッソマシンなど、世界の一流コーヒー器具メーカーの製品を網羅。"
  jaPath="/ja/"
  enPath="/"
>
  <!-- ヒーローセクション -->
  <section class="hero">
    <h1 class="hero__title">Coffee Gear <span>Archive</span></h1>
    <p class="hero__subtitle" style="font-family: var(--font-ja);">
      より良いコーヒーを、あなたの手で。
    </p>
  </section>

  <!-- メインコンテンツ -->
  <div class="container">
    <!-- 簡易説明 -->
    <div style="text-align: center; padding: var(--space-md) 0 var(--space-lg); border-bottom: 1px solid var(--color-border); margin-bottom: var(--space-lg);">
      <p style="font-family: var(--font-ja); max-width: 600px; margin: 0 auto;">
        世界中のコーヒー器具を網羅したデータベース。ハリオ、フェロー、カリタなど、
        一流メーカーのドリッパー、グラインダー、ケトルを詳しく紹介します。
      </p>
    </div>

    <!-- 器具グリッド -->
    <div class="item-grid">
      {gearData.map((gear) => (
        <a href={`/gear/${gear.id}/`} class="item-card">
          <img src={gear.image} alt={gear.nameJa} class="item-card__image" loading="lazy" />
          <div class="item-card__body">
            <p class="item-card__type">{gear.category}</p>
            <h3 class="item-card__name" style="font-family: var(--font-ja);">{gear.nameJa}</h3>
            <p class="item-card__brand">{gear.brand}</p>
            <div class="item-card__meta">
              <span class="item-card__tag">{gear.category}</span>
              <span class="item-card__tag">{gear.brewMethod}</span>
              <span class="item-card__price">${gear.price}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- 英語版への誘導 -->
    <div style="text-align: center; padding: var(--space-xl) 0;">
      <a href="/" class="btn">View Full English Site</a>
    </div>
  </div>
</Base>
