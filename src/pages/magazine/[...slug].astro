---
// magazine/[...slug].astro - 記事詳細ページ
// Markdownの記事をレンダリングして表示
// relatedGearフィールドから関連商品カードも表示する

import Article from '../../layouts/Article.astro';
import RelatedProducts from '../../components/RelatedProducts.astro';
import { getCollection, render } from 'astro:content';
import gearData from '../../data/gear.json';

// 静的パス生成（全記事からパスを生成）
export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

// 記事データを取得
const { article } = Astro.props;

// MarkdownをHTMLにレンダリング
const { Content } = await render(article);

// frontmatterのrelatedGearからIDを取得し、gear.jsonとマッチング
const relatedIds = article.data.relatedGear || [];
const matchedGear = relatedIds.map((id: string) =>
  gearData.find((g: any) => g.id === id)
).filter(Boolean);
---

<Article
  title={article.data.title}
  description={article.data.description}
  category={article.data.category}
  publishedAt={article.data.publishedAt}
  updatedAt={article.data.updatedAt}
  tags={article.data.tags}
>
  <Content />
  <RelatedProducts gear={matchedGear} />
</Article>
