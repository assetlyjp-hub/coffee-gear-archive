---
// brands/[id].astro - ブランド詳細ページ
// ブランドの詳細情報とそのブランドの器具一覧を表示

import Base from '../../layouts/Base.astro';
import GearCard from '../../components/GearCard.astro';

import brandsData from '../../data/brands.json';
import gearData from '../../data/gear.json';

// 静的パス生成
export function getStaticPaths() {
  return brandsData.map((brand) => ({
    params: { id: brand.id },
  }));
}

const { id } = Astro.params;
const brand = brandsData.find(b => b.id === id);
if (!brand) return Astro.redirect('/404');

// そのブランドの器具を取得
const brandGear = gearData.filter(g => g.brand === id);
---

<Base
  title={`${brand.name} (${brand.nameJa})`}
  description={brand.description.slice(0, 160)}
>
  <!-- 一覧への戻りリンク -->
  <div class="container" style="padding-top: calc(var(--space-md) + 60px);">
    <a href="/brands/" style="font-size: 0.85rem; color: var(--color-text-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 0.3rem; transition: color 0.2s;">
      <span>&larr;</span> Back to Brands
    </a>
  </div>

  <!-- ブランドヘッダー -->
  <div class="page-header" style="padding-top: var(--space-sm);">
    <h1 class="page-header__title">{brand.name}</h1>
    <p style="font-family: var(--font-ja); font-size: 1.1rem; color: var(--color-text-sub); margin-bottom: 0.5rem;">{brand.nameJa}</p>
    <p class="page-header__description">Est. {brand.founded} · {brand.country}</p>
  </div>

  <div class="container container--narrow">
    <!-- ブランド説明 -->
    <div style="padding: var(--space-lg) 0;">
      <p style="margin-bottom: var(--space-md); line-height: 1.9;">{brand.description}</p>
      <div class="spec-grid" style="border-bottom: none;">
        <div class="spec-item">
          <span class="spec-item__label">Country</span>
          <span class="spec-item__value">{brand.country}</span>
        </div>
        <div class="spec-item">
          <span class="spec-item__label">Founded</span>
          <span class="spec-item__value">{brand.founded}</span>
        </div>
        <div class="spec-item">
          <span class="spec-item__label">Specialty</span>
          <span class="spec-item__value">{brand.specialty}</span>
        </div>
      </div>
      {brand.officialUrl && (
        <p style="margin-top: var(--space-md);">
          <a href={brand.officialUrl} class="btn btn--sm" target="_blank" rel="noopener noreferrer">Visit Official Website</a>
        </p>
      )}
    </div>

    <!-- そのブランドの器具一覧 -->
    {brandGear.length > 0 && (
      <div style="padding: var(--space-lg) 0; border-top: 1px solid var(--color-border);">
        <h2 style="margin-bottom: var(--space-md);">Gear by {brand.name}</h2>
        <div class="item-grid">
          {brandGear.map((gear) => (
            <GearCard
              id={gear.id}
              name={gear.name}
              brand={gear.brand}
              category={gear.category}
              brewMethod={gear.brewMethod}
              price={gear.price}
              image={gear.image}
            />
          ))}
        </div>
      </div>
    )}
  </div>
</Base>
